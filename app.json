{
  "expo": {
    "name": "今日なに食べる？",
    "slug": "meshi-app",
    "owner": "takehiro5585",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./icon.png",
    "splash": {
      "backgroundColor": "#0e0b07"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.takehiro5585.meshiapp",
      "icon": "./icon.png",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "近くのレストランを探すために位置情報を使用します。"
      }
    },
    "android": {
      "package": "com.takehiro5585.meshiapp",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"],
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#FF6B6B"
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "近くのレストランを探すために位置情報を使用します。"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-9360230936754650~5232823603"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "12e7afb0-1b4f-4aeb-877c-9526f4de7275"
      }
    }
  }
}
